{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/yelp/refs/heads/main/json-schema/yelp-coordinates-schema.json",
  "title": "Coordinates",
  "description": "Coordinates schema from Yelp Fusion API",
  "type": "object",
  "properties": {
    "latitude": {
      "type": "number",
      "format": "double",
      "example": 37.7867
    },
    "longitude": {
      "type": "number",
      "format": "double",
      "example": -122.4112
    }
  }
}